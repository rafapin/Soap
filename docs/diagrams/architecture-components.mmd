flowchart LR
    User["Usuario / evaluador"] --> Web["Dashboard SvelteKit<br/>localhost:3000"]
    Web -->|HTTP server-side fetch| API["FastAPI<br/>localhost:8000"]
    API --> Routes["Rutas API<br/>alarms, metrics, health"]
    Routes --> Services["Servicios<br/>consultas, metricas, ingesta"]
    Services --> Repos["Repositorios SQLAlchemy"]
    Repos --> DB[("PostgreSQL<br/>scada_db")]

    Generator["generate_dataset.py"] --> Raw["CSV / JSON sintetico"]
    Raw --> Loader["load_dataset.py"]
    Loader --> ETL["Pipeline ETL<br/>readers, parsers, transformers, loaders"]
    ETL --> DB

    Compose["Docker Compose"] --> Web
    Compose --> API
    Compose --> DB

